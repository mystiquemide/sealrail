# Sealrail Backend — Environment Configuration
# Copy to .env and fill in values.
# No secrets in this file — this is a template only.

# Database
DATABASE_PATH=./data/sealrail.db

# Blocky AS (TEE verification adapter)
BLOCKY_MODE=tee_adapter
BLOCKY_AS_API_KEY=
BLOCKY_AS_HOST=
BLOCKY_CONFIG_PATH=
BLOCKY_WASM_DIR=../blocky/invoice-verifier

# Casper Network
# Mode: dry_run (default, no chain), testnet (public testnet), mainnet (fail-closed, not yet implemented)
CASPER_MODE=dry_run
# Testnet RPC node (use any Casper testnet peer)
CASPER_RPC_URL=http://136.243.187.125:7777
# Testnet chain name
CASPER_CHAIN_NAME=casper-test
# Path to Casper account secret key PEM file (required for testnet/mainnet)
CASPER_ACCOUNT_KEY_PATH=
# Contract hash — set after deploying contract (Step 7 in Phase P runbook)
CASPER_CONTRACT_HASH=
# CSPR.cloud API (optional data queries)
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_TOKEN=

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Security
API_KEY_SCRYPT_SALT_LENGTH=32
API_KEY_HASH_LENGTH=64
