# Sealrail Backend — Environment Configuration
# Copy to .env and fill in values.
# No secrets in this file — this is a template only.
#
# DEPLOYMENT MODES:
#   dry_run  — Local development, no real chain or TEE. All verification simulated.
#   testnet  — Casper testnet with real contract anchoring. Requires TEE config.
#   mainnet  — NOT YET IMPLEMENTED. Fails closed if selected.
#
# QUICK START (dry_run):
#   cp .env.example .env
#   npm install && npm run dev
#   Server starts on http://localhost:3001 with simulated verification.

# ═══════════════════════════════════════════
# Database
# ═══════════════════════════════════════════
DATABASE_PATH=./data/sealrail.db
# Use :memory: for ephemeral/test runs (data lost on restart)

# ═══════════════════════════════════════════
# Blocky AS — TEE Verification Adapter
# ═══════════════════════════════════════════
# Mode: tee_adapter (local CLI) or hosted_tee (when Blocky API key is available)
BLOCKY_MODE=tee_adapter
# Hosted Blocky API key — contact info@blocky.rocks to request access
BLOCKY_AS_API_KEY=
# Hosted Blocky API host
BLOCKY_AS_HOST=
# Config path for Blocky
BLOCKY_CONFIG_PATH=
# Directory containing the main.wasm for TEE verification
BLOCKY_WASM_DIR=../blocky/invoice-verifier

# ═══════════════════════════════════════════
# Casper Network
# ═══════════════════════════════════════════
# Mode: dry_run (default, no chain), testnet (public testnet), mainnet (NOT IMPLEMENTED — fail closed)
CASPER_MODE=dry_run
# Testnet RPC node
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
# Chain name: casper-test for testnet, casper for mainnet
CASPER_CHAIN_NAME=casper-test
# Path to Casper account secret key PEM file (required for testnet/mainnet)
CASPER_ACCOUNT_KEY_PATH=
# Contract package/hash deployed in Phase P
# Current testnet deploy: hash-02f9771e9cd4d91c40705563074bc323d45a341a11987464367ac909cc845846
CASPER_CONTRACT_HASH=hash-02f9771e9cd4d91c40705563074bc323d45a341a11987464367ac909cc845846
# CSPR.cloud API key (optional, for on-chain data queries)
CSPR_CLOUD_API_KEY=
# CSPR.cloud access token (optional)
CSPR_CLOUD_TOKEN=

# ═══════════════════════════════════════════
# Server
# ═══════════════════════════════════════════
PORT=3001
HOST=0.0.0.0
# NODE_ENV: development, production, or test
NODE_ENV=development

# ═══════════════════════════════════════════
# Security
# ═══════════════════════════════════════════
API_KEY_SCRYPT_SALT_LENGTH=32
API_KEY_HASH_LENGTH=64

# ═══════════════════════════════════════════
# Phase N: LLM Provider — Agent Execution Runtime
# ═══════════════════════════════════════════
# Provider: openai_compatible (OpenAI, OpenRouter, Groq, etc.) or none to disable
LLM_PROVIDER=openai_compatible
# API base URL for the LLM provider
#   OpenAI:     https://api.openai.com
#   OpenRouter: https://openrouter.ai/api
#   Groq:       https://api.groq.com/openai
LLM_API_BASE_URL=
# API key for the LLM provider (never commit real keys)
LLM_API_KEY=
# Model to use for agent execution (e.g., gpt-4o-mini, meta-llama/llama-4-maverick)
LLM_MODEL=gpt-4o-mini
# Timeout in milliseconds for LLM requests
LLM_TIMEOUT_MS=30000
# Max retries on transient errors (rate limits, timeouts)
LLM_MAX_RETRIES=2

# ═══════════════════════════════════════════
# Deployment Checklist
# ═══════════════════════════════════════════
# For dry_run (development):
#   [x] DATABASE_PATH set
#   [ ] No other required fields
#
# For testnet (Casper testnet with real anchoring):
#   [ ] CASPER_MODE=testnet
#   [ ] CASPER_RPC_URL pointing to a real testnet RPC node
#   [ ] CASPER_CHAIN_NAME=casper-test
#   [ ] CASPER_ACCOUNT_KEY_PATH pointing to a valid secret key PEM
#   [ ] CASPER_CONTRACT_HASH set to the deployed contract hash
#   [ ] casper-client installed on PATH
#   [ ] bky-as CLI installed on PATH
#   [ ] BLOCKY_AS_API_KEY and BLOCKY_AS_HOST set (when hosted access available)
#   [ ] LLM_API_BASE_URL and LLM_API_KEY set (for agent execution)
#
# For production (mainnet — NOT YET SUPPORTED):
#   Mainnet mode fails closed. Do not set CASPER_MODE=mainnet.
#   Use testnet for real-chain testing until mainnet is implemented.
