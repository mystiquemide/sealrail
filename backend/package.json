{
  "name": "sealrail-backend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Sealrail backend - TEE-verified agent payment infrastructure on Casper",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
