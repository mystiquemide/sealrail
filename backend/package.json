    "seed": "node dist/scripts/seed.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.7.0",
    "casper-js-sdk": "^5.0.16-beta2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "tsx": "^4.19.0",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "22.x"
  }
}
