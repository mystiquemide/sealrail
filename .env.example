# Casper / CSPR.cloud
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_TOKEN=
CASPER_RPC_URL=https://rpc.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_ACCOUNT_KEY_PATH=

# Blocky AS
# local-server = development mode, not hosted TEE
# hosted-tee = real Blocky AS once key/server are issued
BLOCKY_MODE=local-server
BLOCKY_AS_API_KEY=
BLOCKY_AS_HOST=local-server
BLOCKY_CONFIG_PATH=/root/.config/bky/bky-as/config.toml
BLOCKY_VERIFIER_DIR=./blocky/invoice-verifier
BLOCKY_EXPECTED_FUNCTION=verifyInvoiceRisk
BLOCKY_EXPECTED_CODE_HASH=

# Backend
NODE_ENV=development
PORT=8787
DATABASE_URL=./data/app.db

# Frontend
# Backend's real dev port is 3001 (see backend/.env.example) — this scaffold-era
# .env.example predates that; update if the backend port config ever changes.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BLOCKY_MODE=local-server
NEXT_PUBLIC_CASPER_CHAIN_NAME=casper-test
