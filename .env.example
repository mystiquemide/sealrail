# Sealrail frontend environment — copy to .env.local
# Backend configuration lives in backend/.env.example (full annotated template).

# Base URL of the Sealrail API. The backend dev server listens on 3001.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public site URL used for absolute Open Graph / Twitter card image links.
# Set to the deployed frontend origin in production. Defaults to localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
